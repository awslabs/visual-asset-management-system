<Window x:Class="VamsConnector.LoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VAMS Login" 
        Height="400" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Login to VAMS" 
                   FontSize="16" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" 
                   Text="Username:" 
                   Margin="0,0,0,5"/>
        
        <TextBox Grid.Row="2" 
                 x:Name="UsernameTextBox" 
                 Margin="0,0,0,15" 
                 Height="25"
                 Padding="5"/>

        <TextBlock Grid.Row="3" 
                   x:Name="CredentialLabel"
                   Text="Password:" 
                   Margin="0,0,0,5"/>
        
        <!-- Password field for Cognito auth -->
        <PasswordBox Grid.Row="4" 
                     x:Name="PasswordBox" 
                     Margin="0,0,0,15" 
                     Height="25"
                     Padding="5"
                     PasswordChar="●"/>
        
        <!-- JWT Token field for External auth (hidden by default) -->
        <TextBox Grid.Row="4"
                 x:Name="TokenTextBox"
                 Margin="0,0,0,15"
                 Height="80"
                 Padding="5"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 Visibility="Collapsed"
                 FontFamily="Consolas"
                 FontSize="10"/>

        <StackPanel Grid.Row="5" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="Login" 
                    Width="75" 
                    Height="30" 
                    Margin="0,0,10,0" 
                    Click="LoginButton_Click" 
                    IsDefault="True"
                    Background="#0078D4"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Cancel" 
                    Width="75" 
                    Height="30" 
                    Click="CancelButton_Click" 
                    IsCancel="True"
                    Background="#E1E1E1"
                    BorderThickness="1"
                    BorderBrush="#CCCCCC"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
